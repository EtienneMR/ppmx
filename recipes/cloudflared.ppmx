const REPO = "cloudflare/cloudflared";

fn latest_version() {
    github::latest_release(global::REPO);
}

fn build(ctx) {
    const arch = #{
        "x86_64": "amd64",
        "aarch64": "arm64",
        "arm": "arm",
    }[ctx.arch];

    ctx.download(
        github::asset_url(global::REPO, ctx.version, `cloudflared-${ctx.os}-${arch}`),
        "cloudflared"
    );

    ctx.run("chmod", ["+x", "cloudflared"]);

    ctx.export_root(".");
    ctx.export_exe("cloudflared", "cloudflared");
}
