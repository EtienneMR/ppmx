REPO = "EtienneMR/tbx"


def latest_version():
    return github.latest_release(REPO)


def build(ctx):
    ctx.download(
        github.asset_url(REPO, ctx.version, "tbx-linux"),
        "tbx",
    )

    ctx.run("chmod", "+x", "tbx")

    ctx.run("mkdir", "-p", "completions")
    comp = ctx.run("./tbx", "completion", "zsh")
    ctx.write("completions/zsh", comp)
    
    comp = ctx.run("./tbx", "completion", "bash")
    ctx.write("completions/bash", comp)

    return "."

def install(ctx):
    ctx.exe("tbx", "tbx")
    ctx.share("completions/zsh", "zsh/site-functions/_tbx")
    ctx.share("completions/bash", "bash-completion/completions/tbx")
